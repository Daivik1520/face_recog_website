<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FaceID AI — The Future of Identity Verification</title>
    <meta name="description" content="AI-powered face recognition that replaces manual roll calls, badge scanners, and sign-in sheets with a single camera.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- Nav -->
    <nav class="nav" id="nav">
        <div class="nav-wrap">
            <a href="#" class="logo">
                <svg class="logo-svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                    <circle cx="12" cy="12" r="11" stroke="url(#lg)" stroke-width="1.5"/>
                    <circle cx="12" cy="10" r="3.5" stroke="url(#lg)" stroke-width="1.2"/>
                    <path d="M6 21c0-3.314 2.686-6 6-6s6 2.686 6 6" stroke="url(#lg)" stroke-width="1.2" stroke-linecap="round"/>
                    <defs><linearGradient id="lg" x1="0" y1="0" x2="24" y2="24"><stop stop-color="#818cf8"/><stop offset="1" stop-color="#38bdf8"/></linearGradient></defs>
                </svg>
                FaceID AI
            </a>
            <div class="nav-menu" id="navMenu">
                <a href="#story">Story</a>
                <a href="#how">How</a>
                <a href="#sectors">Sectors</a>
                <a href="#traction">Traction</a>
                <a href="#founder">About</a>
            </div>
            <a href="https://github.com/Daivik1520/facial_recognition" target="_blank" class="nav-btn">GitHub ↗</a>
            <button class="burger" id="burger" aria-label="Menu">
                <span></span><span></span>
            </button>
        </div>
    </nav>

    <!-- ════════ HERO ════════ -->
    <section class="hero">
        <div class="hero-bg-text">RECOGNITION</div>
        <div class="hero-orbs">
            <div class="orb orb-1"></div>
            <div class="orb orb-2"></div>
            <div class="orb orb-3"></div>
        </div>
        <div class="hero-grid-bg"></div>
        <div class="hero-body">
            <div class="hero-chip reveal">
                <span class="chip-dot"></span> Deployed & live in production
            </div>
            <h1 class="hero-h1">
                <span class="reveal">The camera</span>
                <span class="reveal">already knows</span>
                <span class="reveal accent-line scan-effect">who you are.</span>
            </h1>
            <p class="hero-p reveal">
                One AI camera replaces every roll call, badge scanner, and sign-in sheet — across schools, hospitals, offices, and beyond.
            </p>
            <div class="hero-btns reveal">
                <a href="https://github.com/Daivik1520/facial_recognition" target="_blank" class="btn-fill">View on GitHub <span class="arrow">↗</span></a>
                <a href="#story" class="btn-line">Read the story</a>
            </div>
        </div>
        <div class="hero-fade"></div>
    </section>

    <!-- ════════ STORY (Scroll-reveal narrative) ════════ -->
    <section class="story" id="story">
        <div class="narrow">
            <p class="big-text split-text">Every day, <strong>2.6 billion</strong> people are tracked with paper sheets, plastic badges, and spoken names.</p>
            <p class="big-text split-text">Teachers waste <strong>30+ hours a year</strong> on roll calls. Offices lose millions to buddy punching. Hospitals can't verify who enters restricted wards.</p>
            <p class="big-text split-text accent-text">It's 2026. We built something better.</p>
        </div>
    </section>

    <!-- ════════ HOW IT WORKS ════════ -->
    <section class="how-section" id="how">
        <div class="narrow">
            <span class="chip reveal">How it works</span>
            <h2 class="sec-h2 reveal">Walk in. Get recognized. <span class="accent-text">That's it.</span></h2>
            <p class="sec-p reveal">FaceID AI uses one camera and deep learning to identify every person entering a room — in real time, fully offline, with zero manual input.</p>
        </div>
        <div class="container">
            <div class="steps-row">
                <div class="step-card reveal">
                    <div class="step-num">01</div>
                    <div class="step-icon">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 3h4a2 2 0 012 2v4M9 21H5a2 2 0 01-2-2v-4M21 15v4a2 2 0 01-2 2h-4M3 9V5a2 2 0 012-2h4"/><circle cx="12" cy="10" r="3"/><path d="M7 20.662V19a2 2 0 012-2h6a2 2 0 012 2v1.662"/></svg>
                    </div>
                    <h4>Enroll</h4>
                    <p>Guided 15-photo capture from every angle, with 15× AI data augmentation for maximum accuracy.</p>
                </div>
                <div class="step-card reveal">
                    <div class="step-num">02</div>
                    <div class="step-icon">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                    </div>
                    <h4>Recognize</h4>
                    <p>Faces are detected and identified at 30fps. People are recognized the instant they appear — no pause, no queue.</p>
                </div>
                <div class="step-card reveal">
                    <div class="step-num">03</div>
                    <div class="step-icon">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                    </div>
                    <h4>Analyze</h4>
                    <p>Attendance logs auto-populate. Trends, reports, and absentee alerts — all on a real-time dashboard.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ════════ METRICS ════════ -->
    <section class="metrics" id="metrics">
        <div class="container">
            <div class="metric-row">
                <div class="m reveal">
                    <span class="m-num" data-target="95">0</span><span class="m-suf">%</span>
                    <span class="m-label">Accuracy</span>
                </div>
                <div class="m-div"></div>
                <div class="m reveal">
                    <span class="m-num" data-target="30">0</span><span class="m-suf">FPS</span>
                    <span class="m-label">Real-Time</span>
                </div>
                <div class="m-div"></div>
                <div class="m reveal">
                    <span class="m-zero">ZERO</span>
                    <span class="m-label">Cloud Dependencies</span>
                </div>
                <div class="m-div"></div>
                <div class="m reveal">
                    <span class="m-num" data-target="15">0</span><span class="m-suf">×</span>
                    <span class="m-label">Data Augmentation</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ════════ FEATURES ════════ -->
    <section class="feat-section">
        <div class="container">
            <div class="feat-grid">
                <div class="feat reveal">
                    <div class="feat-ico">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                    </div>
                    <h4>Instant Detection</h4>
                    <p>ArcFace + YOLO pipeline detects and identifies in under 33ms per frame.</p>
                </div>
                <div class="feat reveal">
                    <div class="feat-ico">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                    </div>
                    <h4>100% Private</h4>
                    <p>Everything runs locally. No cloud, no external calls. Data never leaves the building.</p>
                </div>
                <div class="feat reveal">
                    <div class="feat-ico">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    </div>
                    <h4>Smart Duplicates</h4>
                    <p>Attendance logs prevent re-counting — each person is marked once per session.</p>
                </div>
                <div class="feat reveal">
                    <div class="feat-ico">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    </div>
                    <h4>FAISS Search</h4>
                    <p>Facebook's vector search enables sub-millisecond matching across hundreds of profiles.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ════════ SECTORS ════════ -->
    <section class="sectors" id="sectors">
        <div class="container">
            <span class="chip reveal">Where it works</span>
            <h2 class="sec-h2 reveal">Built for every door that needs to know <span class="accent-text">who walks in.</span></h2>
            <div class="sector-grid">
                <div class="sector reveal">
                    <div class="sector-tag">Live</div>
                    <span class="sector-ico">🏫</span>
                    <h4>Education</h4>
                    <p>Automate attendance. Identify absentees. Replace roll calls entirely.</p>
                </div>
                <div class="sector reveal">
                    <span class="sector-ico">🏢</span>
                    <h4>Corporate</h4>
                    <p>Face-based entry. No badges, no buddy-punching, no fraud.</p>
                </div>
                <div class="sector reveal">
                    <span class="sector-ico">🏥</span>
                    <h4>Healthcare</h4>
                    <p>Patient verification, staff tracking, and restricted-zone access.</p>
                </div>
                <div class="sector reveal">
                    <span class="sector-ico">🎪</span>
                    <h4>Events</h4>
                    <p>Face-based ticketing, VIP detection, crowd security.</p>
                </div>
                <div class="sector reveal">
                    <span class="sector-ico">🏛️</span>
                    <h4>Government</h4>
                    <p>Facility access, checkpoint identity, visitor management.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ════════ TECH ════════ -->
    <section class="tech">
        <div class="container">
            <div class="tech-strip reveal">
                <div class="t-item"><strong>ArcFace</strong><span>Recognition</span></div>
                <div class="t-item"><strong>YOLO</strong><span>Detection</span></div>
                <div class="t-item"><strong>FAISS</strong><span>Search</span></div>
                <div class="t-item"><strong>FastAPI</strong><span>Backend</span></div>
                <div class="t-item"><strong>Next.js</strong><span>Frontend</span></div>
                <div class="t-item"><strong>InsightFace</strong><span>Analysis</span></div>
            </div>
        </div>
    </section>

    <!-- ════════ TRACTION ════════ -->
    <section class="traction" id="traction">
        <div class="narrow">
            <div class="traction-box reveal">
                <div class="traction-top-line"></div>
                
                <div class="traction-content">
                    <div class="traction-text">
                        <span class="chip chip-g">Real-world traction</span>
                        <h2 class="sec-h2">Already running at a <span class="accent-text">government school.</span></h2>
                        <p class="traction-p">FaceID AI is live at <strong>PM SHRI Jawahar Navodaya Vidyalaya, Rangareddy</strong> — a government school in Telangana. It runs daily, processing attendance for hundreds of students through CCTV cameras. Teachers no longer call names. The system simply <em>knows</em>.</p>
                    </div>
                    <div class="traction-logo">
                        <img src="https://upload.wikimedia.org/wikipedia/en/thumb/5/52/Navodaya_Vidyalaya_Samiti_logo.svg/300px-Navodaya_Vidyalaya_Samiti_logo.svg.png" alt="Navodaya Vidyalaya Samiti Logo">
                    </div>
                </div>

                <div class="traction-nums">
                    <div><strong>Hundreds</strong><span>Students Enrolled</span></div>
                    <div><strong>Daily</strong><span>Active Usage</span></div>
                    <div><strong>CCTV</strong><span>Integration</span></div>
                </div>
            </div>
        </div>
    </section>

    <!-- ════════ ROADMAP ════════ -->
    <section class="roadmap">
        <div class="narrow">
            <span class="chip reveal">Roadmap</span>
            <h2 class="sec-h2 reveal">The journey has <span class="accent-text">just begun.</span></h2>
            <div class="rm-list">
                <div class="rm reveal">
                    <div class="rm-dot rm-done"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div>
                    <div>
                        <span class="rm-phase">Complete</span>
                        <h4>Core Engine</h4>
                        <p>Real-time detection, enrollment, auto-attendance, analytics dashboard</p>
                    </div>
                </div>
                <div class="rm reveal">
                    <div class="rm-dot rm-active"></div>
                    <div>
                        <span class="rm-phase">In Progress</span>
                        <h4>Multi-Camera + CCTV</h4>
                        <p>Multi-feed support, optimized latency pipeline</p>
                    </div>
                </div>
                <div class="rm reveal">
                    <div class="rm-dot"></div>
                    <div>
                        <span class="rm-phase">Next</span>
                        <h4>Enterprise Scale</h4>
                        <p>PostgreSQL, Redis caching, multi-tenant architecture</p>
                    </div>
                </div>
                <div class="rm reveal">
                    <div class="rm-dot"></div>
                    <div>
                        <span class="rm-phase">Vision</span>
                        <h4>Mobile + ML Insights</h4>
                        <p>Companion app, behavioral analytics, predictive alerts</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ════════ FOUNDER ════════ -->
    <section class="founder" id="founder">
        <div class="narrow">
            <div class="founder-box reveal">
                <div class="founder-av"><span>DR</span></div>
                <div class="founder-info">
                    <span class="chip">The Builder</span>
                    <h2 class="founder-name">Daivik Reddy</h2>
                    <p class="founder-age">16 years old · Student & AI Developer</p>
                    <p class="founder-bio">Built and deployed a production face recognition system at his own school before turning 17. Passionate about using AI to solve real, everyday problems — outside the lab, in the real world.</p>
                    <div class="founder-row">
                        <a href="https://github.com/Daivik1520" target="_blank" class="f-btn">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                            GitHub
                        </a>
                        <a href="https://www.linkedin.com/in/daivik-reddy-60a876311/" target="_blank" class="f-btn">
